#!/usr/bin/env python3
"""Autonomous agent loop — switches between codex/claude on usage limit."""

from __future__ import annotations

import hashlib
import json
import os
import re
import shutil
import signal
import subprocess
import sys
import threading
import time
from io import StringIO
from pathlib import Path

REPO = Path(__file__).parent
PROMPT_FILE = REPO / "docs" / "prompt-shakedown.md"
STATE_FILE = REPO / ".agent" / "run-loop-state.json"
COMPLETE_MARKER = REPO / ".agent" / "complete-shakedown.md"
RUN_LOOP_IGNORED_PROGRESS_PREFIXES = (".agent/complete-",)
RUN_LOOP_IGNORED_PROGRESS_PATHS = {".agent/run-loop-state.json"}


def derive_complete_marker(prompt_file: Path, repo: Path) -> Path:
    """Derive completion marker path from prompt filename.

    `docs/prompt-cm.md` -> `.agent/complete-cm.md`
    `docs/prompt-spl-feasibility.md` -> `.agent/complete-spl-feasibility.md`
    `docs/foo.md` -> `.agent/complete-foo.md`
    """
    stem = prompt_file.stem
    suffix = stem[len("prompt-") :] if stem.startswith("prompt-") else stem
    return repo / ".agent" / f"complete-{suffix}.md"


def _filter_progress_paths(paths: tuple[str, ...]) -> tuple[str, ...]:
    filtered = []
    for path in paths:
        if path in RUN_LOOP_IGNORED_PROGRESS_PATHS:
            continue
        if any(
            path.startswith(prefix) for prefix in RUN_LOOP_IGNORED_PROGRESS_PREFIXES
        ):
            continue
        filtered.append(path)
    return tuple(sorted(filtered))


def collect_repo_snapshot(repo_root: Path) -> dict[str, tuple[str, ...]]:
    result = subprocess.run(
        ["git", "status", "--short", "--untracked-files=all"],
        cwd=repo_root,
        check=True,
        capture_output=True,
        text=True,
    )
    tracked_paths: list[str] = []
    untracked_paths: list[str] = []
    for line in result.stdout.splitlines():
        if not line:
            continue
        status = line[:2]
        path = line[3:]
        if status == "??":
            untracked_paths.append(path)
        else:
            tracked_paths.append(path)
    head_result = subprocess.run(
        ["git", "rev-parse", "--verify", "HEAD"],
        cwd=repo_root,
        check=False,
        capture_output=True,
        text=True,
    )
    head = (head_result.stdout.strip(),) if head_result.returncode == 0 else ()
    return {
        "head": head,
        "tracked_paths": tuple(sorted(tracked_paths)),
        "untracked_paths": tuple(sorted(untracked_paths)),
    }


def has_useful_repo_progress(
    before: dict[str, tuple[str, ...]], after: dict[str, tuple[str, ...]]
) -> bool:
    if before.get("head", ()) != after.get("head", ()):
        return True
    before_tracked = _filter_progress_paths(before["tracked_paths"])
    after_tracked = _filter_progress_paths(after["tracked_paths"])
    before_untracked = _filter_progress_paths(before["untracked_paths"])
    after_untracked = _filter_progress_paths(after["untracked_paths"])
    return (before_tracked, before_untracked) != (after_tracked, after_untracked)


def parse_meminfo(text: str) -> dict[str, int | None]:
    """Extract selected values from /proc/meminfo text."""
    mem_available_kib: int | None = None
    for line in text.splitlines():
        if line.startswith("MemAvailable:"):
            parts = line.split()
            if len(parts) >= 2 and parts[1].isdigit():
                mem_available_kib = int(parts[1])
    return {"mem_available_kib": mem_available_kib}


def has_swap(text: str) -> bool:
    """Return True when /proc/swaps has at least one configured swap entry."""
    lines = [line for line in text.splitlines() if line.strip()]
    return len(lines) > 1


def evaluate_claude_preflight(
    mem_available_kib: int | None,
    swap_enabled: bool,
    tmp_total_bytes: int,
    tmp_used_bytes: int,
    claude_tmp_bytes: int,
) -> dict[str, object]:
    """Return a structured decision for Claude preflight safety."""
    reasons: list[str] = []

    if mem_available_kib is None or mem_available_kib < CLAUDE_MIN_MEM_AVAILABLE_KIB:
        reasons.append("low_mem")

    if (
        mem_available_kib is not None
        and mem_available_kib < CLAUDE_MARGIN_MEM_AVAILABLE_KIB
        and not swap_enabled
    ):
        reasons.append("no_swap")

    tmp_ratio = tmp_used_bytes / tmp_total_bytes if tmp_total_bytes > 0 else 0.0
    if (
        tmp_ratio >= TMP_PRESSURE_USED_RATIO
        and claude_tmp_bytes >= CLAUDE_TMP_PRESSURE_BYTES
    ):
        reasons.append("tmp_pressure")

    return {
        "ok": not reasons,
        "reasons": reasons,
        "mem_available_kib": mem_available_kib,
        "swap_enabled": swap_enabled,
        "tmp_total_bytes": tmp_total_bytes,
        "tmp_used_bytes": tmp_used_bytes,
        "claude_tmp_bytes": claude_tmp_bytes,
    }


def format_preflight_error(decision: dict[str, object]) -> str:
    """Format a Claude preflight failure for operator-facing stderr output."""
    mem_available_kib = decision["mem_available_kib"]
    mem_mib = (
        "unknown" if mem_available_kib is None else str(int(mem_available_kib) // 1024)
    )
    swap_text = "enabled" if decision["swap_enabled"] else "none"
    tmp_used_mib = int(decision["tmp_used_bytes"]) // (1024 * 1024)
    tmp_total_mib = int(decision["tmp_total_bytes"]) // (1024 * 1024)
    claude_tmp_mib = int(decision["claude_tmp_bytes"]) // (1024 * 1024)

    lines = [
        "run-loop: refusing to launch Claude due to likely memory pressure.",
        f"run-loop: MemAvailable: {mem_mib} MiB; swap: {swap_text}.",
        (
            f"run-loop: /tmp usage: {tmp_used_mib}/{tmp_total_mib} MiB; "
            f"Claude temp usage: {claude_tmp_mib} MiB under /tmp/claude-*."
        ),
        (
            "run-loop: remediation: remove stale /tmp/claude-* directories, "
            "add swap, then rerun."
        ),
    ]
    return "\n".join(lines)


def format_resource_failure_error(result: dict[str, object], exit_code: int) -> str:
    """Format a Claude post-exit resource failure diagnostic."""
    kind = result["kind"]
    return "\n".join(
        [
            "run-loop: Claude terminated due to likely memory pressure.",
            f"run-loop: exit classification: {kind}; exit code: {exit_code}.",
            (
                "run-loop: remediation: remove stale /tmp/claude-* directories, "
                "add swap, then rerun."
            ),
        ]
    )


def _has_claude_resource_failure_text(output: str) -> bool:
    """Return True when output contains specific resource-pressure evidence."""
    oom_patterns = [
        r"\bOut of memory\b",
        r"\bOOM\b",
        r"\bOOM-kill\b",
        r"\bKilled process\b.*\bclaude\b",
    ]
    return any(re.search(pattern, output, re.IGNORECASE) for pattern in oom_patterns)


def classify_claude_resource_failure(exit_code: int, output: str) -> dict[str, object]:
    """Classify Claude exits that look like resource-pressure failures."""
    if exit_code < 0 and abs(exit_code) == signal.SIGKILL:
        if not _has_claude_resource_failure_text(output):
            return {"is_resource_failure": False, "kind": None}
        return {"is_resource_failure": True, "kind": "signal"}

    if _has_claude_resource_failure_text(output):
        return {"is_resource_failure": True, "kind": "oom_text"}

    return {"is_resource_failure": False, "kind": None}


def get_tmp_usage_bytes(tmp_path: Path) -> tuple[int, int]:
    """Return total and used bytes for a filesystem path."""
    stat = os.statvfs(tmp_path)
    total_bytes = stat.f_frsize * stat.f_blocks
    available_bytes = stat.f_frsize * stat.f_bavail
    used_bytes = total_bytes - available_bytes
    return total_bytes, used_bytes


def _sum_file_bytes(path: Path) -> int:
    """Return recursive size for a file or directory."""
    if path.is_symlink():
        return 0
    if path.is_file():
        return path.stat().st_size
    if path.is_dir():
        total = 0
        for child in path.iterdir():
            total += _sum_file_bytes(child)
        return total
    return 0


def sum_claude_tmp_bytes(tmp_path: Path) -> int:
    """Return recursive size of /tmp/claude-* directories."""
    total = 0
    for path in tmp_path.iterdir():
        if path.name.startswith("claude-") and not path.is_symlink():
            total += _sum_file_bytes(path)
    return total


def find_claude_tmp_paths_for_cleanup(
    tmp_path: Path, threshold_bytes: int
) -> tuple[list[Path], bool]:
    """Return cleanup candidates and whether a Claude temp path crossed the limit."""
    paths: list[Path] = []
    threshold_crossed = False
    for path in sorted(tmp_path.iterdir()):
        if path.name.startswith("claude-") and not path.is_symlink():
            paths.append(path)
            if _sum_file_bytes(path) > threshold_bytes:
                threshold_crossed = True
    return paths, threshold_crossed


def cleanup_claude_tmp_if_needed(
    *, consecutive_claude_resource_failures: int, tmp_path: Path
) -> bool:
    """Delete Claude temp paths after repeated failures if threshold is crossed."""
    if consecutive_claude_resource_failures < 3:
        return False
    paths, threshold_crossed = find_claude_tmp_paths_for_cleanup(
        tmp_path, CLAUDE_TMP_CLEANUP_THRESHOLD_BYTES
    )
    if not threshold_crossed:
        return False
    for path in paths:
        shutil.rmtree(path, ignore_errors=False)
    return True


def gather_claude_host_facts() -> dict[str, object]:
    """Collect Linux host facts needed for Claude preflight."""
    meminfo = parse_meminfo(Path("/proc/meminfo").read_text())
    swap_enabled = has_swap(Path("/proc/swaps").read_text())
    tmp_total_bytes, tmp_used_bytes = get_tmp_usage_bytes(Path("/tmp"))
    claude_tmp_bytes = sum_claude_tmp_bytes(Path("/tmp"))
    return {
        "mem_available_kib": meminfo["mem_available_kib"],
        "swap_enabled": swap_enabled,
        "tmp_total_bytes": tmp_total_bytes,
        "tmp_used_bytes": tmp_used_bytes,
        "claude_tmp_bytes": claude_tmp_bytes,
    }


DEFAULT_STATE = {"last_used": "codex", "both_limited": False}

_LIMIT_PATTERNS = {
    "codex": re.compile(r"You've hit your usage limit"),
    "claude": re.compile(r"You've hit your limit"),
}

CLAUDE_MIN_MEM_AVAILABLE_KIB = 768 * 1024
CLAUDE_MARGIN_MEM_AVAILABLE_KIB = 1024 * 1024
TMP_PRESSURE_USED_RATIO = 0.90
CLAUDE_TMP_PRESSURE_BYTES = 512 * 1024 * 1024
CLAUDE_TMP_CLEANUP_THRESHOLD_BYTES = 700 * 1024 * 1024


def validate_default_prompt_path(prompt_file: Path) -> None:
    """Fail fast when the repo default prompt is intentionally unavailable."""
    if prompt_file.exists():
        return
    print(
        "run-loop: default prompt path is unavailable. Pass an explicit prompt path.",
        file=sys.stderr,
    )
    sys.exit(1)


def validate_explicit_prompt_path(prompt_file: Path, prompt_arg: str) -> None:
    """Fail fast when an operator supplied an unavailable prompt path."""
    if prompt_file.exists():
        return
    print(f"run-loop: prompt path is unavailable: {prompt_arg}", file=sys.stderr)
    sys.exit(1)


def expand_refs(text: str, repo_root: Path) -> str:
    """Expand @file references, wrapping content in === delimiters."""
    lines = []
    for line in text.splitlines():
        m = re.match(r"^@(.+)$", line)
        if m:
            ref = m.group(1)
            path = repo_root / ref
            try:
                if path.is_dir():
                    entries = sorted(
                        p.name + ("/" if p.is_dir() else "") for p in path.iterdir()
                    )
                    content = "\n".join(entries) if entries else "(empty directory)"
                else:
                    content = path.read_text()
            except FileNotFoundError:
                content = f"(file not found: {ref})"
            lines.append(f"=== {ref} ===\n{content}\n=== end {ref} ===")
        else:
            lines.append(line)
    return "\n".join(lines)


def is_limit_message(text: str, backend: str) -> bool:
    """Return True if text contains a usage limit message for backend."""
    pattern = _LIMIT_PATTERNS.get(backend)
    return bool(pattern and pattern.search(text))


def load_state(path: Path) -> dict:
    """Load state JSON, returning defaults on missing or corrupt file."""
    try:
        return normalize_state(json.loads(path.read_text()))
    except (FileNotFoundError, json.JSONDecodeError, OSError):
        return default_state()


def save_state(path: Path, state: dict) -> None:
    """Write state JSON, creating parent directories as needed."""
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(normalize_state(state), indent=2))


def default_state() -> dict[str, object]:
    """Return the persisted state schema with defaults."""
    return {
        "last_used": "codex",
        "both_limited": False,
        "cooldown_until": 0,
        "consecutive_recoverable_failures": 0,
        "consecutive_claude_resource_failures": 0,
        "last_failure_kind": None,
        "last_output_fingerprint": None,
    }


def normalize_state(state: dict[str, object]) -> dict[str, object]:
    """Return the persisted state schema, dropping unknown keys by design."""
    normalized = default_state()
    for key in normalized:
        if key in state:
            normalized[key] = state[key]
    return normalized


def reset_success_counters(state: dict[str, object]) -> None:
    """Clear failure streaks after useful progress."""
    state["both_limited"] = False
    state["consecutive_recoverable_failures"] = 0
    state["consecutive_claude_resource_failures"] = 0
    state["last_failure_kind"] = None


def enter_cooldown(state: dict[str, object]) -> None:
    """Persist cooldown state and sleep for the cooldown interval."""
    state["cooldown_until"] = int(time.time()) + 3600
    save_state(STATE_FILE, state)
    time.sleep(3600)


def fingerprint_output(output: str) -> str:
    """Return a stable fingerprint of backend output."""
    return hashlib.sha256(output.strip().encode("utf-8")).hexdigest()


def classify_iteration(
    *,
    backend: str,
    exit_code: int,
    output: str,
    before_snapshot: dict[str, tuple[str, ...]],
    after_snapshot: dict[str, tuple[str, ...]],
    limit_hit: bool,
    claude_resource_failure: bool,
    prompt_failure: bool = False,
) -> str:
    """Classify a loop iteration outcome."""
    del backend, output
    if has_useful_repo_progress(before_snapshot, after_snapshot):
        return "useful_progress"
    if limit_hit or claude_resource_failure or prompt_failure or exit_code != 0:
        return "recoverable_failure"
    return "recoverable_failure"


def run_backend(backend: str, prompt: str) -> tuple[int, str]:
    """Run backend subprocess, streaming output to terminal and capturing it."""
    stdin_thread = None
    if backend == "claude":
        proc = subprocess.Popen(
            ["claude", "-p", "--dangerously-skip-permissions"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
        )
        stdin_thread = threading.Thread(
            target=lambda: (proc.stdin.write(prompt), proc.stdin.close())
        )
        stdin_thread.start()
    else:
        proc = subprocess.Popen(
            ["codex", "exec", "--dangerously-bypass-approvals-and-sandbox", "-"],
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=subprocess.STDOUT,
            text=True,
        )
        stdin_thread = threading.Thread(
            target=lambda: (proc.stdin.write(prompt), proc.stdin.close())
        )
        stdin_thread.start()

    buf = StringIO()
    for line in proc.stdout:
        sys.stdout.write(line)
        sys.stdout.flush()
        buf.write(line)

    proc.wait()
    if stdin_thread is not None:
        stdin_thread.join()
    return proc.returncode, buf.getvalue()


def main(argv: list[str] | None = None) -> None:
    def _sigint(sig, frame):
        print("\nrun-loop: interrupted")
        sys.exit(0)

    signal.signal(signal.SIGINT, _sigint)

    args = sys.argv[1:] if argv is None else argv
    if args:
        candidate = Path(args[0])
        prompt_file = (
            candidate if candidate.is_absolute() else (REPO / candidate).resolve()
        )
        validate_explicit_prompt_path(prompt_file, args[0])
        complete_marker = derive_complete_marker(prompt_file, REPO)
    else:
        prompt_file = PROMPT_FILE
        complete_marker = COMPLETE_MARKER
        validate_default_prompt_path(prompt_file)

    while True:
        if complete_marker.exists():
            print(f"Completion marker exists: {complete_marker}. Exiting.")
            sys.exit(0)

        state = normalize_state(load_state(STATE_FILE))
        backend = state.get("last_used", "codex")
        both_limited = state.get("both_limited", False)
        cooldown_until = int(state.get("cooldown_until", 0) or 0)
        now = int(time.time())
        if cooldown_until and now < cooldown_until:
            time.sleep(cooldown_until - now)
            continue

        before_snapshot = collect_repo_snapshot(REPO)
        prompt_failure = False
        claude_resource_failure = False
        output = ""
        exit_code = 0

        if backend == "claude":
            host_facts = gather_claude_host_facts()
            decision = evaluate_claude_preflight(
                host_facts["mem_available_kib"],
                host_facts["swap_enabled"],
                host_facts["tmp_total_bytes"],
                host_facts["tmp_used_bytes"],
                host_facts["claude_tmp_bytes"],
            )
            if not decision["ok"]:
                print(format_preflight_error(decision), file=sys.stderr)
                exit_code = 1
                claude_resource_failure = True

        if not claude_resource_failure:
            try:
                expanded = expand_refs(prompt_file.read_text(), REPO)
            except OSError as exc:
                print(f"run-loop: prompt read failed: {exc}", file=sys.stderr)
                expanded = ""
                prompt_failure = True
                exit_code = 1
            if not prompt_failure:
                print(f"--- run-loop: starting {backend} iteration ---")
                exit_code, output = run_backend(backend, expanded)
                if backend == "claude":
                    failure = classify_claude_resource_failure(exit_code, output)
                    if failure["is_resource_failure"]:
                        print(
                            format_resource_failure_error(failure, exit_code),
                            file=sys.stderr,
                        )
                        claude_resource_failure = True
                if exit_code != 0 and not is_limit_message(output, backend):
                    print(f"--- run-loop: {backend} exited with code {exit_code} ---")

        after_snapshot = collect_repo_snapshot(REPO)
        limit_hit = is_limit_message(output, backend)
        classification = classify_iteration(
            backend=backend,
            exit_code=exit_code,
            output=output,
            before_snapshot=before_snapshot,
            after_snapshot=after_snapshot,
            limit_hit=limit_hit,
            claude_resource_failure=claude_resource_failure,
            prompt_failure=prompt_failure,
        )
        fingerprint = fingerprint_output(output)
        if fingerprint == state.get(
            "last_output_fingerprint"
        ) and not has_useful_repo_progress(before_snapshot, after_snapshot):
            classification = "recoverable_failure"

        if classification == "useful_progress":
            state["last_used"] = backend
            reset_success_counters(state)
        else:
            state["consecutive_recoverable_failures"] = (
                int(state.get("consecutive_recoverable_failures", 0)) + 1
            )
            if backend == "claude" and claude_resource_failure:
                state["consecutive_claude_resource_failures"] = (
                    int(state.get("consecutive_claude_resource_failures", 0)) + 1
                )
                if cleanup_claude_tmp_if_needed(
                    consecutive_claude_resource_failures=int(
                        state["consecutive_claude_resource_failures"]
                    ),
                    tmp_path=Path("/tmp"),
                ):
                    print(
                        (
                            "run-loop: deleted all /tmp/claude-* after "
                            "repeated Claude resource failures."
                        ),
                        file=sys.stderr,
                    )
            elif backend == "claude":
                state["consecutive_claude_resource_failures"] = 0

            state["last_failure_kind"] = (
                "limit"
                if limit_hit
                else "no_progress"
                if exit_code == 0
                else "backend_failure"
            )
            other = "claude" if backend == "codex" else "codex"

            if limit_hit and both_limited:
                print("--- run-loop: both backends limited, sleeping 1 hour ---")
                state["last_used"] = other
                state["both_limited"] = False
                state["last_output_fingerprint"] = fingerprint
                enter_cooldown(state)
                continue

            if int(state["consecutive_recoverable_failures"]) >= 2:
                state["last_used"] = other
                state["both_limited"] = False
                state["last_output_fingerprint"] = fingerprint
                enter_cooldown(state)
                continue

            state["last_used"] = other
            state["both_limited"] = bool(limit_hit)

        state["last_output_fingerprint"] = fingerprint
        save_state(STATE_FILE, state)


if __name__ == "__main__":
    main(sys.argv[1:])
