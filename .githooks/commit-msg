#!/usr/bin/env bash
# Enforce Conventional Commits format
commit_msg=$(head -1 "$1")
pattern='^(build|chore|ci|docs|experiment|feat|fix|perf|refactor|revert|style|test)(\([a-z0-9-]+\))?!?: \S.*'
if ! echo "$commit_msg" | grep -qE "$pattern"; then
  echo "ERROR: Commit message must follow Conventional Commits format:" >&2
  echo "" >&2
  echo "  <type>[!]: <description>" >&2
  echo "" >&2
  echo "  Allowed types:" >&2
  echo "    feat        user-facing functionality added to a deliverable (quackdown.sql, test_harness)" >&2
  echo "    fix         bug fix in a deliverable or infrastructure" >&2
  echo "    test        add or fix tests; use this not fix: for test-only changes" >&2
  echo "    docs        documentation, specs, plans, design docs, READMEs" >&2
  echo "    experiment  feasibility study, SQL experiment, or research finding" >&2
  echo "    chore       tooling, infrastructure, config, build, cleanup, renaming" >&2
  echo "    refactor    code restructure with no behaviour change" >&2
  echo "    perf        performance improvement" >&2
  echo "    ci          CI/CD pipeline changes" >&2
  echo "    build       build system changes" >&2
  echo "    style       formatting only" >&2
  echo "    revert      revert a prior commit" >&2
  echo "" >&2
  echo "  Append ! before the colon for breaking changes: feat!: rename tool" >&2
  echo "" >&2
  echo "  Got: $commit_msg" >&2
  exit 1
fi
